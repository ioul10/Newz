# =============================================================================
# NEWZ - Variables d'Environnement
# Fichier : .env.example
# =============================================================================
# Copiez ce fichier en .env et modifiez les valeurs selon votre environnement
# Commande : cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# 1. CONFIGURATION GÉNÉRALE
# -----------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=True
APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# 2. CHEMINS ET STOCKAGE
# -----------------------------------------------------------------------------
DATA_PATH=./data
REPORTS_PATH=./reports
ASSETS_PATH=./assets
TEMPLATES_PATH=./templates

# -----------------------------------------------------------------------------
# 3. SOURCES DE DONNÉES (URLs)
# -----------------------------------------------------------------------------
BOURSE_CASA_URL=https://www.casablanca-bourse.com
BAM_URL=https://www.bkam.ma
ILBOURSA_URL=https://www.ilboursa.com

# -----------------------------------------------------------------------------
# 4. CONFIGURATION PDF
# -----------------------------------------------------------------------------
PDF_FORMAT=A4
PDF_ORIENTATION=portrait
PDF_MARGIN_TOP=2cm
PDF_MARGIN_BOTTOM=2cm
PDF_MARGIN_LEFT=2cm
PDF_MARGIN_RIGHT=2cm

# -----------------------------------------------------------------------------
# 5. EMAIL (Pour envoi des rapports - Optionnel)
# -----------------------------------------------------------------------------
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@cdgcapital.ma
SMTP_PASSWORD=votre-mot-de-passe
EMAIL_FROM=noreply@newz-cdg.com
EMAIL_TO=equipe-marketdata@cdgcapital.ma

# -----------------------------------------------------------------------------
# 6. LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/newz.log

# -----------------------------------------------------------------------------
# 7. CACHE ET PERFORMANCE
# -----------------------------------------------------------------------------
CACHE_TTL=3600
MAX_RETRIES=3
REQUEST_TIMEOUT=10
