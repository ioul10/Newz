# =============================================================================
# NEWZ - .gitignore
# =============================================================================

# Environnement virtuel
venv/
env/
.venv/

# Variables d'environnement (SENSIBLE)
.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Données temporaires
data/*.csv
data/*.json
!data/.gitkeep

# Rapports générés
reports/*.pdf
!reports/.gitkeep

# Assets personnels (logos, etc.)
assets/*.png
assets/*.jpg
!assets/.gitkeep

# Tests
.pytest_cache/
.coverage
htmlcov/

# Streamlit
.streamlit/secrets.toml
